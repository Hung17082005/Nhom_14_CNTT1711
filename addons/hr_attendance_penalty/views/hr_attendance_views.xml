<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Tree View: Danh sách chấm công với hiển thị đi muộn -->
    <record id="view_hr_attendance_tree_late" model="ir.ui.view">
        <field name="name">hr.attendance.tree.late</field>
        <field name="model">hr.attendance</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <tree string="Danh sách chấm công" 
                  decoration-danger="is_late"
                  decoration-warning="is_invalid_time">
                <field name="employee_id" />
                <field name="check_in" />
                <field name="check_out" />
                <field name="work_hours_computed" sum="Tổng giờ" />
                <field name="is_late" />
                <field name="late_minutes" />
                <field name="is_invalid_time" />
            </tree>
        </field>
    </record>

    <!-- Form View: Chi tiết chấm công (extend hiện tại) -->
    <record id="view_hr_attendance_form_late" model="ir.ui.view">
        <field name="name">hr.attendance.form.late</field>
        <field name="model">hr.attendance</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Chấm công">
                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" />
                            <field name="check_in" />
                            <field name="check_out" />
                        </group>
                        <group>
                            <field name="work_hours_computed" readonly="1" />
                            <field name="is_late" readonly="1" />
                            <field name="late_minutes" readonly="1" />
                            <field name="is_invalid_time" readonly="1" 
                                   attrs="{'invisible': [('is_invalid_time', '=', False)]}" />
                        </group>
                    </group>
                    <div class="alert alert-warning" 
                         attrs="{'invisible': [('is_invalid_time', '=', False)]}">
                        ⚠️ Cảnh báo: Giờ ra (check_out) bé hơn giờ vào (check_in)!
                        Vui lòng kiểm tra lại dữ liệu.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Thêm trường is_late và late_minutes vào tree view mặc định của hr.attendance -->
    <record id="view_hr_attendance_tree" model="ir.ui.view">
        <field name="name">hr.attendance.tree</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id">hr_attendance.view_hr_attendance_tree</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <xpath expr="/tree" position="attributes">
                <attribute name="decoration-danger">is_late</attribute>
                <attribute name="decoration-warning">is_invalid_time</attribute>
            </xpath>
            <field name="worked_hours" position="after">
                <field name="work_hours_computed" />
                <field name="is_late" />
                <field name="late_minutes" />
                <field name="is_invalid_time" />
            </field>
        </field>
    </record>

    <!-- Extend Form View: Thêm các fields mới -->
    <record id="view_hr_attendance_form" model="ir.ui.view">
        <field name="name">hr.attendance.form</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id">hr_attendance.view_hr_attendance_form</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <field name="check_out" position="after">
                <field name="work_hours_computed" readonly="1" />
                <field name="is_invalid_time" readonly="1" />
            </field>
            <field name="worked_hours" position="after">
                <field name="is_late" readonly="1" />
                <field name="late_minutes" readonly="1" />
            </field>
        </field>
    </record>

    <!-- Search View: Lọc theo đi muộn -->
    <record id="view_hr_attendance_search" model="ir.ui.view">
        <field name="name">hr.attendance.search</field>
        <field name="model">hr.attendance</field>
        <field name="inherit_id">hr_attendance.view_hr_attendance_search</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <filter name="today" position="after">
                <separator />
                <filter name="late" string="✓ Đi muộn" domain="[('is_late', '=', True)]" />
                <filter name="not_late" string="✓ Không muộn" domain="[('is_late', '=', False)]" />
                <filter name="invalid_data" string="⚠️ Dữ liệu không hợp lệ" 
                        domain="[('is_invalid_time', '=', True)]" />
            </filter>
        </field>
    </record>

</odoo>
