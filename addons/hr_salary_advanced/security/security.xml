<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Record-level security rules -->

    <!-- Employees can only see their own shift registers -->
    <record id="rule_hr_shift_register_employee" model="ir.rule">
        <field name="name">hr.shift.register: Employee can only see own</field>
        <field name="model_id" ref="model_hr_shift_register"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Employees can only see their own payslips -->
    <record id="rule_bang_luong_employee" model="ir.rule">
        <field name="name">bang.luong: Employee can only see own</field>
        <field name="model_id" ref="model_bang_luong"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
    </record>

    <!-- Employees can only see their own attendance records -->
    <record id="rule_hr_attendance_employee" model="ir.rule">
        <field name="name">hr.attendance: Employee can only see own</field>
        <field name="model_id" ref="hr_attendance.model_hr_attendance"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
    </record>

    <!-- HR Manager can see all -->
    <!-- (Default rules for hr.group_hr_manager - no domain restriction) -->

</odoo>
