<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- bang.luong (Payslip) -->

    <record id="view_bang_luong_tree" model="ir.ui.view">
        <field name="name">bang.luong.tree</field>
        <field name="model">bang.luong</field>
        <field name="arch" type="xml">
            <tree>
                <field name="employee_id"/>
                <field name="month"/>
                <field name="actual_days"/>
                <field name="salary_by_days" sum="Cộng"/>
                <field name="overtime_bonus" sum="Cộng"/>
                <field name="total_insurance" sum="Cộng"/>
                <field name="late_penalty" sum="Cộng"/>
                <field name="net_salary" sum="Cộng"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <record id="view_bang_luong_form" model="ir.ui.view">
        <field name="name">bang.luong.form</field>
        <field name="model">bang.luong</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_lines" string="🔄 Tính Lương" type="object" class="oe_highlight" states="draft"/>
                    <button name="action_confirm" string="✓ Xác Nhận" type="object" class="oe_highlight" states="draft"/>
                    <button name="action_draft" string="Quay Lại Nháp" type="object" states="done,cancel"/>
                    <button name="action_cancel" string="Hủy" type="object" states="draft,done"/>
                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <group>
                            <field name="employee_id" readonly="1"/>
                            <field name="month" readonly="1"/>
                        </group>
                        <group>
                            <field name="basic_salary" readonly="1" widget="monetary"/>
                            <field name="standard_days" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- Salary Details Tab -->
                        <page name="salary_details" string="💰 Chi Tiết Lương">
                            <group>
                                <group string="Công Làm Việc">
                                    <field name="actual_days" readonly="1"/>
                                    <field name="overtime_days" readonly="1"/>
                                    <field name="salary_by_days" readonly="1" widget="monetary"/>
                                    <field name="overtime_bonus" readonly="1" widget="monetary"/>
                                </group>
                                <group string="Khoản Trừ">
                                    <field name="total_insurance" readonly="1" widget="monetary"/>
                                    <field name="late_penalty" readonly="1" widget="monetary"/>
                                    <field name="total_deductions" readonly="1" widget="monetary"/>
                                </group>
                            </group>
                        </page>

                        <!-- Summary Tab -->
                        <page name="summary" string="📊 Tóm Tắt">
                            <group>
                                <div class="o_summary">
                                    <table class="table table-sm">
                                        <tr style="background-color: #d4edda;">
                                            <td><strong>Lương Cơ Bản:</strong></td>
                                            <td style="text-align: right;"><strong><field name="salary_by_days" readonly="1" widget="monetary"/></strong></td>
                                        </tr>
                                        <tr>
                                            <td><strong>Thưởng Công Vượt:</strong></td>
                                            <td style="text-align: right;"><strong><field name="overtime_bonus" readonly="1" widget="monetary"/></strong></td>
                                        </tr>
                                        <tr style="background-color: #f8d7da;">
                                            <td><strong>Bảo Hiểm:</strong></td>
                                            <td style="text-align: right;"><strong><field name="total_insurance" readonly="1" widget="monetary"/></strong></td>
                                        </tr>
                                        <tr style="background-color: #f8d7da;">
                                            <td><strong>Phạt Đi Muộn:</strong></td>
                                            <td style="text-align: right;"><strong><field name="late_penalty" readonly="1" widget="monetary"/></strong></td>
                                        </tr>
                                        <tr style="background-color: #cfe2ff; font-size: 16px;">
                                            <td><strong>THỰC LÃNH:</strong></td>
                                            <td style="text-align: right; font-size: 18px;"><strong><field name="net_salary" readonly="1" widget="monetary"/></strong></td>
                                        </tr>
                                    </table>
                                </div>
                            </group>
                        </page>

                        <!-- Line Details Tab -->
                        <page name="line_details" string="📝 Chi Tiết Dòng">
                            <field name="line_ids" nolabel="1">
                                <tree>
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="type"/>
                                    <field name="amount" sum="Tổng"/>
                                    <field name="description"/>
                                </tree>
                            </field>
                        </page>

                        <!-- Notes Tab -->
                        <page name="notes" string="📌 Ghi Chú">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search view -->
    <record id="view_bang_luong_search" model="ir.ui.view">
        <field name="name">bang.luong.search</field>
        <field name="model">bang.luong</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="month"/>
                <separator/>
                <filter name="draft" string="Bản Nháp" domain="[('state', '=', 'draft')]"/>
                <filter name="done" string="Hoàn Tất" domain="[('state', '=', 'done')]"/>
                <filter name="cancel" string="Hủy" domain="[('state', '=', 'cancel')]"/>
            </search>
        </field>
    </record>

</odoo>
