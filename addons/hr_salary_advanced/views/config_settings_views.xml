<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Settings view -->
    <record id="view_hr_salary_advanced_settings" model="ir.ui.view">
        <field name="name">res.config.settings.hr.salary.advanced</field>
        <field name="model">res.config.settings</field>
        <field name="arch" type="xml">
            <form string="Cài Đặt HR Salary Advanced" class="oe_form_configuration">
                <header>
                    <button name="execute" string="Lưu" type="object" class="oe_highlight"/>
                    <button name="cancel" string="Hủy" type="object" class="oe_link"/>
                </header>
                <sheet>
                    <h2>⚙️ Cài Đặt Lương</h2>

                    <!-- Attendance Settings -->
                    <group name="attendance" string="⏰ Chấm Công">
                        <field name="standard_check_in_time" widget="char"/>
                    </group>

                    <!-- Salary Calculation -->
                    <group name="salary" string="💰 Tính Lương">
                        <field name="basic_salary" widget="monetary"/>
                        <field name="standard_working_days" widget="integer"/>
                        <field name="overtime_rate" widget="monetary"/>
                    </group>

                    <!-- Penalties -->
                    <group name="penalties" string="⚠️ Phạt & Thưởng">
                        <field name="penalty_per_minute" widget="monetary"/>
                    </group>

                    <!-- Insurance -->
                    <group name="insurance" string="🏥 Bảo Hiểm Nhân Viên">
                        <field name="insurance_bhxh_rate" widget="float" string="BHXH (%)"/>
                        <field name="insurance_bhyt_rate" widget="float" string="BHYT (%)"/>
                        <field name="insurance_bhtn_rate" widget="float" string="BHTN (%)"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
