<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payslip Wizard -->
    <record id="view_payslip_wizard_form" model="ir.ui.view">
        <field name="name">payslip.wizard.form</field>
        <field name="model">payslip.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="month" required="1"/>
                        <field name="employee_ids" widget="many2many_tags" placeholder="Để trống để tạo cho tất cả"/>
                        <field name="note" nolabel="1" placeholder="Ghi chú (tùy chọn)"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_create_payslips" string="Tạo Phiếu Lương" type="object" class="oe_highlight"/>
                    <button string="Hủy" class="oe_link" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open wizard -->
    <act_window id="action_payslip_wizard" name="Tạo Phiếu Lương" res_model="payslip.wizard" src_model="bang.luong" view_mode="form" target="new" key2="client_action_multi"/>

</odoo>
