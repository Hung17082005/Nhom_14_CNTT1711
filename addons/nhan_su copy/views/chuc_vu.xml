<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_chuc_vu_form" model="ir.ui.view">
            <field name="name">chuc_vu.form</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <div class="oe_title">
                            <label for="ten_chuc_vu" class="oe_edit_only" string="Tên chức vụ"/>
                            <h1><field name="ten_chuc_vu" placeholder="VD: Trưởng phòng Nhân sự"/></h1>
                        </div>
                        <group>
                            <group string="Thông tin định danh">
                                <field name="ma_chuc_vu"/>
                                <field name="currency_id" groups="base.group_multi_currency" invisible="1"/>
                            </group>
                            <group string="Định mức lương">
                                <field name="luong_co_ban" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_chuc_vu_tree" model="ir.ui.view">
            <field name="name">chuc_vu.tree</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                    <field name="luong_co_ban" widget="monetary"/>
                </tree>
            </field>
        </record>

        <record model="ir.ui.view" id="chuc_vu_search">
            <field name="name">chuc_vu.search</field>
            <field name="model">chuc_vu</field>
            <field name="arch" type="xml">
                <search>
                    <field name="ma_chuc_vu"/>
                    <field name="ten_chuc_vu"/>
                </search>
            </field>
        </record>

        <record id="action_chuc_vu" model="ir.actions.act_window">
            <field name="name">Danh mục Chức vụ</field>
            <field name="res_model">chuc_vu</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="chuc_vu_search"/>
        </record>

        <menuitem id="menu_payroll_root" name="Quản lý Lương" sequence="10"/>
        
        <menuitem id="menu_payroll_config" name="Cấu hình" parent="menu_payroll_root" sequence="100"/>
        
        <menuitem id="menu_chuc_vu_item" name="Chức vụ" parent="menu_payroll_config" action="action_chuc_vu" sequence="10"/>
    </data>
</odoo>